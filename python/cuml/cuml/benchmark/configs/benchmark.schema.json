{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cuML benchmark manifest",
  "type": "object",
  "required": [
    "version",
    "suite",
    "benchmarks"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": 1
    },
    "suite": {
      "type": "object",
      "required": [
        "name",
        "tier",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "include_tags"
        ],
        "additionalProperties": false,
        "properties": {
          "include_tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        }
      }
    },
    "defaults": {
      "$ref": "#/$defs/benchmarkFields"
    },
    "benchmarks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmark"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "benchmark": {
      "allOf": [
        {
          "$ref": "#/$defs/benchmarkFields"
        },
        {
          "type": "object",
          "required": [
            "algorithm"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "algorithm": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "benchmarkFields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        },
        "input_type": {
          "enum": [
            "numpy",
            "pandas",
            "cupy",
            "cudf"
          ]
        },
        "dtype": {
          "enum": [
            "fp32",
            "fp64"
          ]
        },
        "n_reps": {
          "type": "integer",
          "minimum": 1
        },
        "random_state": {
          "type": [
            "integer",
            "null"
          ]
        },
        "test_split": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "run_cpu": {
          "type": "boolean"
        },
        "run_gpu": {
          "type": "boolean"
        },
        "backends": {
          "type": "array",
          "items": {
            "enum": [
              "cpu",
              "gpu"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "raise_on_error": {
          "type": "boolean"
        },
        "default_size": {
          "type": "boolean"
        },
        "operation": {
          "enum": [
            "fit",
            "predict",
            "transform",
            "fit_transform",
            "fit_predict",
            "fit_kneighbors",
            "kneighbors"
          ]
        },
        "rows": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "features": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "shapes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rows",
              "features"
            ],
            "additionalProperties": false,
            "properties": {
              "rows": {
                "type": "integer",
                "minimum": 1
              },
              "features": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "minItems": 1
        },
        "params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cuml_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cpu_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "dataset_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cuml_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cpu_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "dataset_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "comparison": {
          "$ref": "#/$defs/freeformObject"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/freeformObject"
        },
        "variants": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/variant"
          },
          "minProperties": 1
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id_suffix": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        },
        "input_type": {
          "enum": [
            "numpy",
            "pandas",
            "cupy",
            "cudf"
          ]
        },
        "dtype": {
          "enum": [
            "fp32",
            "fp64"
          ]
        },
        "n_reps": {
          "type": "integer",
          "minimum": 1
        },
        "random_state": {
          "type": [
            "integer",
            "null"
          ]
        },
        "test_split": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "run_cpu": {
          "type": "boolean"
        },
        "run_gpu": {
          "type": "boolean"
        },
        "backends": {
          "type": "array",
          "items": {
            "enum": [
              "cpu",
              "gpu"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "raise_on_error": {
          "type": "boolean"
        },
        "default_size": {
          "type": "boolean"
        },
        "operation": {
          "enum": [
            "fit",
            "predict",
            "transform",
            "fit_transform",
            "fit_predict",
            "fit_kneighbors",
            "kneighbors"
          ]
        },
        "rows": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "features": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "shapes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rows",
              "features"
            ],
            "additionalProperties": false,
            "properties": {
              "rows": {
                "type": "integer",
                "minimum": 1
              },
              "features": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "minItems": 1
        },
        "params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cuml_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cpu_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "dataset_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cuml_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cpu_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "dataset_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "comparison": {
          "$ref": "#/$defs/freeformObject"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/freeformObject"
        },
        "tiers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/tier"
          },
          "minProperties": 1
        }
      }
    },
    "tier": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id_suffix": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        },
        "input_type": {
          "enum": [
            "numpy",
            "pandas",
            "cupy",
            "cudf"
          ]
        },
        "dtype": {
          "enum": [
            "fp32",
            "fp64"
          ]
        },
        "n_reps": {
          "type": "integer",
          "minimum": 1
        },
        "random_state": {
          "type": [
            "integer",
            "null"
          ]
        },
        "test_split": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "run_cpu": {
          "type": "boolean"
        },
        "run_gpu": {
          "type": "boolean"
        },
        "backends": {
          "type": "array",
          "items": {
            "enum": [
              "cpu",
              "gpu"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "raise_on_error": {
          "type": "boolean"
        },
        "default_size": {
          "type": "boolean"
        },
        "operation": {
          "enum": [
            "fit",
            "predict",
            "transform",
            "fit_transform",
            "fit_predict",
            "fit_kneighbors",
            "kneighbors"
          ]
        },
        "rows": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "features": {
          "$ref": "#/$defs/positiveIntegerArray"
        },
        "shapes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rows",
              "features"
            ],
            "additionalProperties": false,
            "properties": {
              "rows": {
                "type": "integer",
                "minimum": 1
              },
              "features": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "minItems": 1
        },
        "params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cuml_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "cpu_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "dataset_params": {
          "$ref": "#/$defs/freeformObject"
        },
        "param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cuml_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "cpu_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "dataset_param_grid": {
          "$ref": "#/$defs/paramGrid"
        },
        "comparison": {
          "$ref": "#/$defs/freeformObject"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/freeformObject"
        }
      }
    },
    "positiveIntegerArray": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "minItems": 1
    },
    "paramGrid": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1
      }
    },
    "freeformObject": {
      "type": "object"
    }
  }
}
